    dealDelay: 0
    dealRewardRatio: 0
    blocksEvents: 0
    requiredSkills: []
    statConditions: []
  - displayName: Step Down and Walk Away
    description: Step away from the spotlight and pull all your support from the
      war to prevent further escalation.
    supportModifier: -5
    suspicionModifier: 0
    politicalInfluenceModifier: 0
    costModifier: 0
    endsWar: 0
    warEndDelay: 0
    reducesReward: 0
    baseRewardReduction: 0
    endsWarWithDeal: 0
    dealDelay: 0
    dealRewardRatio: 0
    blocksEvents: 1
    requiredSkills: []
    statConditions: []
  - displayName: Send the Mafia
    description: Use your mafia to track down those behind the threat and deal with
      them, but expect a significant rise in Suspicion.
    supportModifier: 2
    suspicionModifier: 0.5
    politicalInfluenceModifier: 0
    costModifier: 0
