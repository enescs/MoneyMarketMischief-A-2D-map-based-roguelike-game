  id: wfoevent03
  displayName: Leverage Through Family
  description: A foreign intelligence agency is threatening to kidnap your child
    to force certain decisions. This crisis puts you between personal safety and
    strategic interests, potentially impacting your Wealth, Suspicion, and Trust
    balance.
  devNote: "mafya skilleri olu\u015Fturuldu\u011Funda se\xE7enekler k\u0131sm\u0131na
    eklenecek"
  minWarTime: 0
  decisionTime: 31
  isRepeatable: 0
  maxRepeatCount: 1
  choices:
  - displayName: Ignore the Threats
    description: Refuse to bend under pressure and keep your course unchanged
    supportModifier: 0.3
    suspicionModifier: 0
    politicalInfluenceModifier: 0
    costModifier: 0
    endsWar: 0
    warEndDelay: 0
    reducesReward: 0
    baseRewardReduction: 0
