  id: wfoevent01
  displayName: The Minister of Defense wants to end the war.
  description: "Rising casualties and political pressure have pushed peace talks
    to the table. You can sabotage the process, accelerate it, or quietly steer it
    for your own gain \u2014 but every move will shift your Wealth, Suspicion, and
    Trust balance."
  devNote: "Mafya skilleri olu\u015Fturulunca se\xE7eneklere eklenecek\nR\xFC\u015Fvet
    Skilleri olu\u015Fturulunca eklenecek se\xE7eneklere"
  minWarTime: 90
  decisionTime: 30
  isRepeatable: 0
  maxRepeatCount: 1
  choices:
  - displayName: Negotiate With Minister
    description: Strike a deal with the Minister of Defense to keep the war ongoing
      in exchange for shifting power and strategic advantages in your favor.
    supportModifier: 0
    suspicionModifier: 0
    politicalInfluenceModifier: 0
    costModifier: 0
    endsWar: 0
